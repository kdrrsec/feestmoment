# Database — PostgreSQL (aanbevolen: Neon, gratis tier)
# Kopieer je connection string uit Neon: Dashboard → Connect → Connection string
# Zie NEON_SETUP.md
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
# Moet overeenkomen met de URL van je dev-server (zie package.json: next dev -p 4001)
NEXTAUTH_URL="http://localhost:4001"
NEXTAUTH_SECRET="I5mqHw1mgbfpAI8y3UOUHHzgKkvND2oSjKNAedBysx0="

# Stripe (optioneel voor nu - vul later in met echte keys)
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
# Publieke basis-URL (SEO, Open Graph, sitemap/robots) — op Vercel je productie-domein
NEXT_PUBLIC_URL="http://localhost:4001"

# Contact (één bron voor telefoon, WhatsApp, tel:-links op de hele site)
NEXT_PUBLIC_SITE_PHONE="+31612345678"
# Optioneel: leesbare weergave; anders default +31 6 …
# NEXT_PUBLIC_SITE_PHONE_DISPLAY="+31 6 12 34 56 78"
# NEXT_PUBLIC_SITE_EMAIL="info@feestmomentverhuur.nl"

# Social: Facebook-icoon alleen als URL gezet is. Instagram default = feestmomentverhuur
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL="https://www.facebook.com/jouwbedrijf"
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL="https://www.instagram.com/feestmomentverhuur"

# Leads: e-mailnotificatie (Resend — gratis tier op resend.com)
# Maak een API key aan en plak hier. Zonder deze key blijft alles werken; alleen geen mail.
RESEND_API_KEY=""
# Waar nieuwe leads naartoe gaan (jouw eigen adres)
LEAD_NOTIFICATION_EMAIL="info@feestmomentverhuur.nl"
# Optioneel: afzender (alleen als je domein bij Resend hebt geverifieerd)
# RESEND_FROM="Feestmoment <noreply@jouwdomein.nl>"

# Reserveringen: strikte kalender (standaard aan). Bij overlap met een bestaande reservering
# is de periode vol — ook als stockQty hoger is. Zet op false voor parallelle verhuur tot voorraadlimiet.
# RESERVATION_STRICT_CALENDAR="false"

# Admin: productafbeeldingen uploaden (Vercel Blob — vereist op Vercel hosting)
# Lokaal zonder deze key worden bestanden in /public/products gezet.
# Vercel: Project → Storage → Blob → maak store → kopieer read/write token.
# BLOB_READ_WRITE_TOKEN=""
